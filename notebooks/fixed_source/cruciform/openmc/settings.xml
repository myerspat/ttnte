<?xml version='1.0' encoding='UTF-8'?>
<settings>
  <run_mode>fixed source</run_mode>
  <particles>500000</particles>
  <batches>1000</batches>
  <source particle="neutron" strength="1.0" type="independent">
    <space type="box">
      <parameters>0 0 -0.5 2.75 2.75 0.5</parameters>
    </space>
    <angle type="isotropic"/>
    <energy type="discrete">
      <parameters>1.0 1.0</parameters>
    </energy>
    <constraints>
      <domain_type>cell</domain_type>
      <domain_ids>1</domain_ids>
    </constraints>
  </source>
  <output>
    <summary>true</summary>
    <tallies>true</tallies>
  </output>
  <energy_mode>multi-group</energy_mode>
</settings>
